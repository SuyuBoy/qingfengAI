{
  "name": "qingfeng-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:react-route": "tsc --noEmit && vite build --outDir ../react --emptyOutDir",
    "build:github-root": "tsc --noEmit && vite build --outDir ../.react-build --emptyOutDir && cp -R ../.react-build/index.html ../index.html && mkdir -p ../assets && cp -R ../.react-build/assets/. ../assets",
    "preview": "vite preview"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.13",
    "lucide-react": "^1.17.0",
    "marked": "^16.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.3"
  }
}
